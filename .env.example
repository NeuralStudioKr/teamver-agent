# ===== 필수 환경변수 =====

# JWT 서명에 사용되는 비밀 키 (최소 32자 이상 랜덤 문자열 권장)
# 예: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-string

# PostgreSQL 비밀번호 (docker-compose에서 자동 사용)
POSTGRES_PASSWORD=ta_dev_password

# PostgreSQL 연결 URL (docker-compose 사용 시 아래 값 그대로 사용)
DATABASE_URL=postgresql://postgres:ta_dev_password@postgres:5432/teamver_agent

# ===== 고객사 설정 =====

# 워크스페이스 이름 (DB seed에서 사용)
WORKSPACE_NAME=workspace
WORKSPACE_SLUG=default

# 봇 비밀번호 (OpenClaw 봇이 backend에 로그인할 때 사용)
BOT_PASSWORD=change-this-bot-password

# ===== 3 AI 직원 정체성 (DB seed에서 upsert) =====

AI_COORDINATOR_NAME=조율자
AI_COORDINATOR_EMAIL=coordinator@example.local
AI_COORDINATOR_TITLE=조율자

AI_WRITER_NAME=작성자
AI_WRITER_EMAIL=writer@example.local
AI_WRITER_TITLE=작성자

AI_REVIEWER_NAME=검토자
AI_REVIEWER_EMAIL=reviewer@example.local
AI_REVIEWER_TITLE=검토자

# ===== 프론트엔드 =====

# 백엔드 API URL (브라우저에서 접근 가능한 주소)
NEXT_PUBLIC_API_URL=http://localhost:3001
