# ===== 필수 환경변수 =====

# JWT 서명에 사용되는 비밀 키 (최소 32자 이상 랜덤 문자열 권장)
# 예: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-string

# Anthropic API 키 (AI 직원 응답 생성에 사용)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL 비밀번호 (docker-compose에서 자동 사용)
POSTGRES_PASSWORD=ta_dev_password

# PostgreSQL 연결 URL (docker-compose 사용 시 아래 값 그대로 사용)
DATABASE_URL=postgresql://postgres:ta_dev_password@postgres:5432/teamver_agent

# ===== 선택 환경변수 =====

# AI 응답 타임아웃 (밀리초, 기본 10초)
AI_RESPONSE_TIMEOUT_MS=10000

# AI 랜덤 응답 확률 (0.0 ~ 1.0, 기본 20%)
# 언급하지 않아도 AI가 응답할 확률
AI_RANDOM_RESPONSE_CHANCE=0.2

# ===== 프론트엔드 =====

# 백엔드 API URL (브라우저에서 접근 가능한 주소)
NEXT_PUBLIC_API_URL=http://localhost:3001
